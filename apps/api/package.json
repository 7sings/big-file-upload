{
  "name": "@big-upload/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/cli/migrate.ts",
    "cleanup": "tsx src/cli/cleanup.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@big-upload/shared": "1.0.0",
    "@big-upload/upload-core": "1.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/static": "^10.1.0",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@libsql/client": "^0.15.0",
    "@sinclair/typebox": "^0.34.13",
    "fastify": "^5.2.1",
    "dotenv": "^16.4.7",
    "nodemailer": "^9.0.3",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": { "node": ">=20" }
}
