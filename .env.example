# 运行环境：development / production
NODE_ENV=development
# API 监听端口
PORT=3000
# 前端页面的来源地址，用于 CORS 校验
APP_ORIGIN=http://localhost:5173

# Cookie 签名密钥；生产环境必须使用长度不少于 32 字符的随机值
COOKIE_SECRET=replace-with-at-least-32-characters
# OTP 验证码哈希使用的服务端密钥；生产环境必须使用随机值
OTP_PEPPER=replace-with-at-least-32-characters
# 本地文件存储临时上传/下载 URL 的 HMAC 签名密钥
LOCAL_SIGNING_SECRET=replace-with-at-least-32-characters

# 数据库连接地址：本地使用 file:；Turso 使用 libsql://<database>-<organization>.turso.io
DATABASE_URL=file:.data/app.db
# Turso 数据库认证 Token；本地 file: 数据库留空
DATABASE_AUTH_TOKEN=

# Redis 驱动：memory（本地临时内存）或 redis（Render Key Value / Redis）
REDIS_DRIVER=memory
# Redis 连接 URL；仅当 REDIS_DRIVER=redis 时必填
REDIS_URL=

# 邮件驱动：console、resend（推荐用于 Render）或 smtp
MAIL_DRIVER=console
# Resend API Token；仅当 MAIL_DRIVER=resend 时必填
RESEND_API_KEY=
# Resend API 地址和请求超时；通常无需修改
RESEND_API_URL=https://api.resend.com
RESEND_TIMEOUT_MS=10000
# SMTP 服务器地址；仅当 MAIL_DRIVER=smtp 时必填
SMTP_HOST=
# SMTP 端口，常见值为 587（STARTTLS）或 465（SMTPS）
SMTP_PORT=587
# 是否直接使用 TLS；465 通常为 true，587 通常为 false（STARTTLS）
SMTP_SECURE=false
# SMTP 地址族：auto 保持双栈；无 IPv6 SMTP 出站路由的部署环境可设为 ipv4
SMTP_ADDRESS_FAMILY=auto
# SMTP 网络超时（毫秒，必须为正整数）
SMTP_DNS_TIMEOUT_MS=3000
SMTP_CONNECTION_TIMEOUT_MS=8000
SMTP_GREETING_TIMEOUT_MS=8000
SMTP_SOCKET_TIMEOUT_MS=15000
# SMTP 用户名
SMTP_USER=
# SMTP 密码或应用专用密码
SMTP_PASS=
# 发件人显示名称和邮箱
MAIL_FROM=Big Upload <no-reply@example.com>

# 存储驱动：local（本地文件系统）或 r2（Cloudflare R2）
STORAGE_DRIVER=local
# 本地存储根目录；仅当 STORAGE_DRIVER=local 时使用
LOCAL_STORAGE_PATH=.data/storage
# R2 的 S3 兼容 Endpoint，例如 https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# R2 区域，通常保持 auto
R2_REGION=auto
# R2 Bucket 名称
R2_BUCKET=
# R2 API Token 的 Access Key ID
R2_ACCESS_KEY_ID=
# R2 API Token 的 Secret Access Key
R2_SECRET_ACCESS_KEY=

# 单文件允许的最大字节数；默认 5 GiB
MAX_FILE_SIZE_BYTES=5368709120
# 每位用户允许同时存在的未完成上传数
MAX_ACTIVE_UPLOADS_PER_USER=5
# 未更新上传会话的过期秒数；清理任务会终止过期 multipart
UPLOAD_STALE_AFTER_SECONDS=86400
# 单个分片预签名上传 URL 的有效期（秒）
PART_URL_TTL_SECONDS=900
# 文件预览/下载 URL 的有效期（秒）
PREVIEW_URL_TTL_SECONDS=300
# 邮箱验证码的有效期（秒）
OTP_TTL_SECONDS=600
# 登录 Session 的有效期（秒）
SESSION_TTL_SECONDS=604800
# Pino 日志等级：silent / error / warn / info / debug
LOG_LEVEL=info
